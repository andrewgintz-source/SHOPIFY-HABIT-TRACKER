{% comment %}
  APEX — How It Works Section
  File: sections/apex-how-it-works.liquid
{% endcomment %}

<style>
  #apex-hiw-{{ section.id }} *,
  #apex-hiw-{{ section.id }} *::before,
  #apex-hiw-{{ section.id }} *::after { box-sizing:border-box;margin:0;padding:0; }
  #apex-hiw-{{ section.id }} {
    --gold:{{ section.settings.accent_color }};
    --gd:rgba(245,197,66,.12);
    --gd2:rgba(245,197,66,.06);
    --bg:{{ section.settings.bg_color }};
    --bg2:#0f0f15; --bg3:#14141c; --bg4:#1a1a26;
    --border:rgba(255,255,255,.07); --border2:rgba(255,255,255,.13);
    --tx:#e8eaf4; --tx2:#7a8296; --tx3:#3c4256;
    --fd:'Bebas Neue','Impact',sans-serif;
    --fm:'JetBrains Mono','Fira Code','Courier New',monospace;
    background:var(--bg); color:var(--tx); font-family:var(--fm);
    position:relative; overflow:hidden;
    padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@300;400;500&display=swap');

  #apex-hiw-{{ section.id }} .hiw-bg {
    position:absolute; inset:0;
    background-image:
      linear-gradient(rgba(245,197,66,.035) 1px,transparent 1px),
      linear-gradient(90deg,rgba(245,197,66,.035) 1px,transparent 1px);
    background-size:64px 64px;
    mask-image:radial-gradient(ellipse 85% 85% at 50% 50%,black,transparent);
    pointer-events:none; z-index:0;
  }
  #apex-hiw-{{ section.id }} .hiw-inner {
    position:relative; z-index:1;
    max-width:1160px; margin:0 auto; padding:0 48px;
  }

  /* Header */
  #apex-hiw-{{ section.id }} .hiw-header { text-align:center; margin-bottom:72px; }
  #apex-hiw-{{ section.id }} .hiw-tag {
    display:inline-flex; align-items:center; gap:10px;
    font-family:var(--fm); font-size:10px; letter-spacing:.28em;
    color:var(--gold); text-transform:uppercase; margin-bottom:22px;
    padding:6px 16px; background:var(--gd); border:1px solid rgba(245,197,66,.2);
  }
  #apex-hiw-{{ section.id }} .hiw-tag::before,
  #apex-hiw-{{ section.id }} .hiw-tag::after { content:''; width:16px; height:1px; background:var(--gold); opacity:.5; }
  #apex-hiw-{{ section.id }} .hiw-h2 {
    font-family:var(--fd); font-size:clamp(44px,6vw,80px);
    line-height:.9; letter-spacing:-.01em; color:var(--tx); margin-bottom:16px;
  }
  #apex-hiw-{{ section.id }} .hiw-h2 span { color:var(--gold); }
  #apex-hiw-{{ section.id }} .hiw-h2-sub {
    font-family:var(--fm); font-size:13px; color:var(--tx2);
    line-height:1.8; max-width:500px; margin:0 auto; letter-spacing:.025em;
  }

  /* connector line */
  #apex-hiw-{{ section.id }} .hiw-steps-wrap { position:relative; }
  #apex-hiw-{{ section.id }} .hiw-connector {
    position:absolute; top:42px; left:calc(16.666% + 24px); right:calc(16.666% + 24px);
    height:1px;
    background:linear-gradient(90deg,transparent,var(--gold),var(--gold),transparent);
    opacity:.25; pointer-events:none; z-index:0;
  }
  #apex-hiw-{{ section.id }} .hiw-connector-dot {
    position:absolute; top:50%; transform:translateY(-50%);
    width:8px; height:8px; border-radius:50%; background:var(--gold);
    animation:hiw-dot-travel 4s ease-in-out infinite;
  }
  @keyframes hiw-dot-travel {
    0%   { left:0%;   opacity:0; }
    10%  { opacity:1; }
    90%  { opacity:1; }
    100% { left:100%; opacity:0; }
  }

  /* steps grid */
  #apex-hiw-{{ section.id }} .hiw-steps {
    display:grid; grid-template-columns:repeat(3,1fr); gap:20px; position:relative; z-index:1;
  }
  #apex-hiw-{{ section.id }} .hiw-step {
    background:var(--bg3); border:1px solid var(--border);
    padding:36px 30px; position:relative; overflow:hidden;
    transition:border-color .3s,transform .3s,box-shadow .3s;
  }
  #apex-hiw-{{ section.id }} .hiw-step:hover {
    border-color:rgba(245,197,66,.4);
    transform:translateY(-5px);
    box-shadow:0 20px 60px rgba(0,0,0,.4);
  }
  #apex-hiw-{{ section.id }} .hiw-step::before {
    content:'';position:absolute;top:0;inset-x:0;height:2px;
    background:linear-gradient(90deg,var(--gold),transparent);
    opacity:0; transition:opacity .3s;
  }
  #apex-hiw-{{ section.id }} .hiw-step:hover::before { opacity:1; }
  #apex-hiw-{{ section.id }} .hiw-step-bg-num {
    position:absolute; bottom:-12px; right:16px;
    font-family:var(--fd); font-size:100px; color:var(--gold);
    opacity:.04; line-height:1; pointer-events:none; user-select:none;
  }
  #apex-hiw-{{ section.id }} .hiw-step-num-row {
    display:flex; align-items:center; gap:14px; margin-bottom:22px;
  }
  #apex-hiw-{{ section.id }} .hiw-step-num {
    width:54px; height:54px; background:var(--bg4); border:1px solid var(--border2);
    display:flex; align-items:center; justify-content:center;
    font-family:var(--fd); font-size:28px; color:var(--gold); flex-shrink:0;
    position:relative;
  }
  #apex-hiw-{{ section.id }} .hiw-step-num::before {
    content:''; position:absolute; inset:-1px;
    background:linear-gradient(135deg,rgba(245,197,66,.2),transparent);
    z-index:-1;
  }
  #apex-hiw-{{ section.id }} .hiw-step-phase {
    font-family:var(--fm); font-size:9px; color:var(--tx3);
    letter-spacing:.2em; text-transform:uppercase;
  }
  #apex-hiw-{{ section.id }} .hiw-step-icon {
    font-size:36px; margin-bottom:16px; display:block; line-height:1;
  }
  #apex-hiw-{{ section.id }} .hiw-step-title {
    font-family:var(--fd); font-size:28px; color:var(--tx);
    letter-spacing:.04em; line-height:1; margin-bottom:12px;
  }
  #apex-hiw-{{ section.id }} .hiw-step-desc {
    font-family:var(--fm); font-size:11px; color:var(--tx2);
    line-height:1.85; letter-spacing:.03em; margin-bottom:20px;
  }
  #apex-hiw-{{ section.id }} .hiw-step-bullets {
    list-style:none; display:flex; flex-direction:column; gap:0;
  }
  #apex-hiw-{{ section.id }} .hiw-step-bullet {
    font-family:var(--fm); font-size:10px; color:var(--tx2);
    letter-spacing:.05em; padding:7px 0;
    border-bottom:1px solid var(--border);
    display:flex; align-items:center; gap:8px;
  }
  #apex-hiw-{{ section.id }} .hiw-step-bullet:last-child { border-bottom:none; }
  #apex-hiw-{{ section.id }} .hiw-step-bullet::before {
    content:'+'; color:var(--gold); font-size:12px; flex-shrink:0;
  }

  /* bottom bar */
  #apex-hiw-{{ section.id }} .hiw-bottom {
    margin-top:56px; padding-top:48px; border-top:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between; gap:32px; flex-wrap:wrap;
  }
  #apex-hiw-{{ section.id }} .hiw-bottom-text {
    font-family:var(--fm); font-size:12px; color:var(--tx2);
    line-height:1.8; max-width:500px; letter-spacing:.025em;
  }
  #apex-hiw-{{ section.id }} .hiw-bottom-text strong { color:var(--tx); font-weight:500; }
  #apex-hiw-{{ section.id }} .hiw-cta {
    display:inline-block; padding:14px 32px;
    background:var(--gold); color:#0b0b0f;
    font-family:var(--fd); font-size:18px; letter-spacing:.07em; line-height:1;
    text-decoration:none; border:none; transition:all .25s; flex-shrink:0;
  }
  #apex-hiw-{{ section.id }} .hiw-cta:hover { background:#ffd966; transform:translateY(-2px); box-shadow:0 12px 40px rgba(245,197,66,.3); }

  @media(max-width:900px){
    #apex-hiw-{{ section.id }} .hiw-steps { grid-template-columns:1fr; }
    #apex-hiw-{{ section.id }} .hiw-connector { display:none; }
    #apex-hiw-{{ section.id }} .hiw-inner { padding:0 28px; }
    #apex-hiw-{{ section.id }} .hiw-bottom { flex-direction:column; align-items:flex-start; }
  }
  @media(max-width:600px){
    #apex-hiw-{{ section.id }} .hiw-inner { padding:0 20px; }
  }
</style>

<section id="apex-hiw-{{ section.id }}">
  <div class="hiw-bg" aria-hidden="true"></div>
  <div class="hiw-inner">

    <div class="hiw-header">
      <div class="hiw-tag">{{ section.settings.section_tag }}</div>
      <h2 class="hiw-h2">{{ section.settings.headline | replace: section.settings.headline_accent, '<span>' | append: '</span>' }}</h2>
      <p class="hiw-h2-sub">{{ section.settings.subtext }}</p>
    </div>

    <div class="hiw-steps-wrap">
      <div class="hiw-connector" aria-hidden="true"><div class="hiw-connector-dot"></div></div>
      <div class="hiw-steps">
        {% assign step_num = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            {% assign step_num = step_num | plus: 1 %}
            <div class="hiw-step" {{ block.shopify_attributes }}>
              <div class="hiw-step-bg-num" aria-hidden="true">0{{ step_num }}</div>
              <div class="hiw-step-num-row">
                <div class="hiw-step-num">0{{ step_num }}</div>
                <span class="hiw-step-phase">{{ block.settings.phase_label }}</span>
              </div>
              <span class="hiw-step-icon" aria-hidden="true">{{ block.settings.icon }}</span>
              <div class="hiw-step-title">{{ block.settings.title }}</div>
              <p class="hiw-step-desc">{{ block.settings.description }}</p>
              {% unless block.settings.bullets == blank %}
                <ul class="hiw-step-bullets">
                  {% assign bullet_list = block.settings.bullets | split: '|' %}
                  {% for bullet in bullet_list %}
                    <li class="hiw-step-bullet">{{ bullet | strip }}</li>
                  {% endfor %}
                </ul>
              {% endunless %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="hiw-bottom">
      <p class="hiw-bottom-text">{{ section.settings.bottom_text }}</p>
      {% if section.settings.cta_url != blank %}
        <a href="{{ section.settings.cta_url }}" class="hiw-cta"
          {% if section.settings.cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
          {{ section.settings.cta_text }}
        </a>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "APEX How It Works",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0b0b0f" },
    { "type": "color", "id": "accent_color", "label": "Accent (Gold)", "default": "#f5c542" },
    { "type": "text", "id": "section_tag", "label": "Section Tag", "default": "The System" },
    { "type": "textarea", "id": "headline", "label": "Headline", "default": "Three steps to operating at your ceiling." },
    { "type": "text", "id": "headline_accent", "label": "Words to highlight gold", "default": "your ceiling." },
    { "type": "textarea", "id": "subtext", "label": "Subtitle", "default": "APEX is not a to-do app. It's an operating system that runs your day, tracks your growth, and levels you up." },
    { "type": "textarea", "id": "bottom_text", "label": "Bottom paragraph", "default": "Most systems ask you to show up for them. APEX shows up for you — with a daily mission, a running score, and a rank that reflects exactly who you are." },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "Start Your Ascent" },
    { "type": "url", "id": "cta_url", "label": "CTA Button URL" },
    { "type": "checkbox", "id": "cta_new_tab", "label": "Open in new tab", "default": false },
    { "type": "range", "id": "padding_top", "min": 40, "max": 200, "step": 4, "unit": "px", "label": "Padding Top", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 40, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 100 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "phase_label", "label": "Phase Label", "default": "Phase One" },
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🔥" },
        { "type": "text", "id": "title", "label": "Step Title", "default": "Track Your Habits" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Deploy your habit stack. Every asset you track earns XP and builds your audit trail." },
        { "type": "textarea", "id": "bullets", "label": "Bullet points (separate with |)", "default": "Build your habit ledger | Set daily targets | Earn XP per completion" }
      ]
    }
  ],
  "presets": [
    {
      "name": "APEX How It Works",
      "blocks": [
        { "type": "step", "settings": { "phase_label": "Phase One", "icon": "🔥", "title": "Track Your Habits", "description": "Deploy your personal habit stack. Every behavior you track earns XP and builds a 28-day audit trail you can't argue with.", "bullets": "Build your habit ledger | Earn XP per completion | Streak multipliers up to 2×" } },
        { "type": "step", "settings": { "phase_label": "Phase Two", "icon": "🎯", "title": "Complete Missions", "description": "Run your daily task ledger, focus timer sessions, and field journal. Every action logged is a rep in the bank.", "bullets": "Daily mission planner | War room focus timer | Field journal for reflection" } },
        { "type": "step", "settings": { "phase_label": "Phase Three", "icon": "⚡", "title": "Level Up Your Business", "description": "Watch your rank climb from Initiate to God Mode. Unlock achievements, rise on the global leaderboard, and build the identity of an elite operator.", "bullets": "10 ranks from Initiate to God Mode | 15 achievement badges | Global leaderboard" } }
      ]
    }
  ]
}
{% endschema %}