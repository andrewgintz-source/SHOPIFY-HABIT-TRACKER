{% comment %}
  APEX — Tools Section
  File: sections/apex-tools.liquid
{% endcomment %}

<style>
  #apex-tools-{{ section.id }} *,
  #apex-tools-{{ section.id }} *::before,
  #apex-tools-{{ section.id }} *::after { box-sizing:border-box;margin:0;padding:0; }
  #apex-tools-{{ section.id }} {
    --gold:{{ section.settings.accent_color }};
    --gd:rgba(245,197,66,.12); --gd2:rgba(245,197,66,.06); --gd3:rgba(245,197,66,.04);
    --bg:{{ section.settings.bg_color }};
    --bg2:#0f0f15; --bg3:#14141c; --bg4:#1a1a26;
    --border:rgba(255,255,255,.07); --border2:rgba(255,255,255,.13);
    --tx:#e8eaf4; --tx2:#7a8296; --tx3:#3c4256;
    --fd:'Bebas Neue','Impact',sans-serif;
    --fm:'JetBrains Mono','Fira Code','Courier New',monospace;
    background:var(--bg); color:var(--tx); font-family:var(--fm);
    position:relative; overflow:hidden;
    padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@300;400;500&display=swap');

  #apex-tools-{{ section.id }} .at-grid-bg {
    position:absolute; inset:0;
    background-image:linear-gradient(rgba(245,197,66,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(245,197,66,.03) 1px,transparent 1px);
    background-size:64px 64px;
    mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black,transparent);
    pointer-events:none; z-index:0;
  }
  #apex-tools-{{ section.id }} .at-inner {
    position:relative; z-index:1; max-width:1160px; margin:0 auto; padding:0 48px;
  }

  /* header */
  #apex-tools-{{ section.id }} .at-header { margin-bottom:64px; }
  #apex-tools-{{ section.id }} .at-tag {
    display:inline-flex; align-items:center; gap:9px;
    font-family:var(--fm); font-size:10px; letter-spacing:.26em;
    color:var(--gold); text-transform:uppercase; margin-bottom:18px;
  }
  #apex-tools-{{ section.id }} .at-tag::before { content:''; width:18px; height:1px; background:var(--gold); }
  #apex-tools-{{ section.id }} .at-h2 {
    font-family:var(--fd); font-size:clamp(44px,6vw,80px);
    line-height:.9; letter-spacing:-.01em; margin-bottom:14px;
  }
  #apex-tools-{{ section.id }} .at-h2 span { color:var(--gold); }
  #apex-tools-{{ section.id }} .at-h2-sub {
    font-family:var(--fm); font-size:12px; color:var(--tx2);
    line-height:1.85; max-width:520px; letter-spacing:.025em;
  }

  /* tools grid */
  #apex-tools-{{ section.id }} .at-grid {
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:1px;
    background:var(--border2);
    border:1px solid var(--border2);
  }
  #apex-tools-{{ section.id }} .at-card {
    background:var(--bg3); padding:32px 28px;
    position:relative; overflow:hidden;
    transition:background .28s; cursor:default;
  }
  #apex-tools-{{ section.id }} .at-card:hover { background:var(--bg4); }
  #apex-tools-{{ section.id }} .at-card::before {
    content:''; position:absolute; top:0; inset-x:0; height:2px;
    background:linear-gradient(90deg,var(--gold),transparent);
    opacity:0; transition:opacity .3s;
  }
  #apex-tools-{{ section.id }} .at-card:hover::before { opacity:1; }
  /* featured card */
  #apex-tools-{{ section.id }} .at-card.featured {
    background:linear-gradient(160deg,#14141c 0%,#0f0f15 100%);
    border-top:2px solid var(--gold) !important;
  }
  #apex-tools-{{ section.id }} .at-card.featured::before { opacity:1; }
  #apex-tools-{{ section.id }} .at-card-badge {
    display:inline-block; font-family:var(--fm); font-size:8px;
    background:var(--gold); color:#0b0b0f;
    padding:3px 10px; letter-spacing:.12em; text-transform:uppercase;
    margin-bottom:16px;
  }
  #apex-tools-{{ section.id }} .at-card-icon-row {
    display:flex; align-items:center; gap:12px; margin-bottom:16px;
  }
  #apex-tools-{{ section.id }} .at-card-icon {
    width:48px; height:48px; background:var(--bg4); border:1px solid var(--border2);
    display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0;
    transition:border-color .3s;
  }
  #apex-tools-{{ section.id }} .at-card:hover .at-card-icon { border-color:rgba(245,197,66,.4); }
  #apex-tools-{{ section.id }} .at-card.featured .at-card-icon { border-color:var(--gold); background:var(--gd); }
  #apex-tools-{{ section.id }} .at-card-id {
    font-family:var(--fm); font-size:9px; color:var(--tx3);
    letter-spacing:.2em; text-transform:uppercase;
  }
  #apex-tools-{{ section.id }} .at-card-title {
    font-family:var(--fd); font-size:24px; letter-spacing:.04em;
    color:var(--tx); line-height:1; margin-bottom:10px;
  }
  #apex-tools-{{ section.id }} .at-card.featured .at-card-title { color:var(--gold); }
  #apex-tools-{{ section.id }} .at-card-desc {
    font-family:var(--fm); font-size:11px; color:var(--tx2);
    line-height:1.85; letter-spacing:.03em; margin-bottom:18px;
  }
  #apex-tools-{{ section.id }} .at-card-features {
    list-style:none; display:flex; flex-direction:column; gap:0;
  }
  #apex-tools-{{ section.id }} .at-card-feat {
    font-family:var(--fm); font-size:10px; color:var(--tx2);
    padding:6px 0; border-bottom:1px solid var(--border);
    display:flex; align-items:center; gap:7px; letter-spacing:.04em;
  }
  #apex-tools-{{ section.id }} .at-card-feat:last-child { border-bottom:none; }
  #apex-tools-{{ section.id }} .at-card-feat::before { content:'+'; color:var(--gold); flex-shrink:0; }
  /* big number bg */
  #apex-tools-{{ section.id }} .at-card-bgnum {
    position:absolute; bottom:-6px; right:16px;
    font-family:var(--fd); font-size:80px; color:var(--gold);
    opacity:.04; line-height:1; pointer-events:none; user-select:none;
  }

  /* bottom strip */
  #apex-tools-{{ section.id }} .at-strip {
    margin-top:48px; border:1px solid var(--border2);
    display:flex; overflow:hidden;
  }
  #apex-tools-{{ section.id }} .at-strip-item {
    flex:1; padding:22px 20px; border-right:1px solid var(--border);
    text-align:center; transition:background .25s;
  }
  #apex-tools-{{ section.id }} .at-strip-item:last-child { border-right:none; }
  #apex-tools-{{ section.id }} .at-strip-item:hover { background:var(--gd); }
  #apex-tools-{{ section.id }} .at-strip-val {
    font-family:var(--fd); font-size:36px; color:var(--gold); line-height:1; display:block; margin-bottom:5px;
  }
  #apex-tools-{{ section.id }} .at-strip-lbl {
    font-family:var(--fm); font-size:9px; color:var(--tx2); letter-spacing:.15em; text-transform:uppercase;
  }

  @media(max-width:960px){
    #apex-tools-{{ section.id }} .at-grid { grid-template-columns:1fr 1fr; }
    #apex-tools-{{ section.id }} .at-inner { padding:0 28px; }
    #apex-tools-{{ section.id }} .at-strip { flex-wrap:wrap; }
    #apex-tools-{{ section.id }} .at-strip-item { flex:1 1 50%; border-right:none; border-bottom:1px solid var(--border); }
    #apex-tools-{{ section.id }} .at-strip-item:nth-child(odd) { border-right:1px solid var(--border); }
    #apex-tools-{{ section.id }} .at-strip-item:nth-last-child(-n+2) { border-bottom:none; }
  }
  @media(max-width:600px){
    #apex-tools-{{ section.id }} .at-grid { grid-template-columns:1fr; }
    #apex-tools-{{ section.id }} .at-inner { padding:0 20px; }
    #apex-tools-{{ section.id }} .at-strip-item { flex:1 1 100%; border-right:none; }
    #apex-tools-{{ section.id }} .at-strip-item:nth-child(odd) { border-right:none; }
  }
</style>

<section id="apex-tools-{{ section.id }}">
  <div class="at-grid-bg" aria-hidden="true"></div>
  <div class="at-inner">

    <div class="at-header">
      <div class="at-tag">{{ section.settings.section_tag }}</div>
      <h2 class="at-h2">{{ section.settings.headline | replace: section.settings.headline_accent, '<span>' | append: '</span>' }}</h2>
      <p class="at-h2-sub">{{ section.settings.subtext }}</p>
    </div>

    <div class="at-grid">
      {% assign card_num = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'tool' %}
          {% assign card_num = card_num | plus: 1 %}
          <div class="at-card{% if block.settings.featured %} featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="at-card-bgnum" aria-hidden="true">0{{ card_num }}</div>
            {% if block.settings.featured %}<div class="at-card-badge">{{ block.settings.badge_text }}</div>{% endif %}
            <div class="at-card-icon-row">
              <div class="at-card-icon">{{ block.settings.icon }}</div>
              <span class="at-card-id">Tool 0{{ card_num }}</span>
            </div>
            <div class="at-card-title">{{ block.settings.title }}</div>
            <p class="at-card-desc">{{ block.settings.description }}</p>
            {% unless block.settings.features == blank %}
              <ul class="at-card-features">
                {% assign feat_list = block.settings.features | split: '|' %}
                {% for feat in feat_list %}
                  <li class="at-card-feat">{{ feat | strip }}</li>
                {% endfor %}
              </ul>
            {% endunless %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_strip %}
    <div class="at-strip">
      {% for block in section.blocks %}
        {% if block.type == 'strip_stat' %}
          <div class="at-strip-item" {{ block.shopify_attributes }}>
            <span class="at-strip-val">{{ block.settings.value }}</span>
            <span class="at-strip-lbl">{{ block.settings.label }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "APEX Tools",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0b0b0f" },
    { "type": "color", "id": "accent_color", "label": "Accent (Gold)", "default": "#f5c542" },
    { "type": "text", "id": "section_tag", "label": "Section Tag", "default": "The Ledger" },
    { "type": "textarea", "id": "headline", "label": "Headline", "default": "Every tool you need. One operating system." },
    { "type": "text", "id": "headline_accent", "label": "Words to highlight gold", "default": "One operating system." },
    { "type": "textarea", "id": "subtext", "label": "Subtitle", "default": "APEX doesn't bolt on features. Every tool is part of one connected system — designed to compound your discipline, track your assets, and level up your output." },
    { "type": "checkbox", "id": "show_strip", "label": "Show Stats Strip", "default": true },
    { "type": "range", "id": "padding_top", "min": 40, "max": 200, "step": 4, "unit": "px", "label": "Padding Top", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 40, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 100 }
  ],
  "blocks": [
    {
      "type": "tool",
      "name": "Tool Card",
      "settings": [
        { "type": "checkbox", "id": "featured", "label": "Featured card (gold border)", "default": false },
        { "type": "text", "id": "badge_text", "label": "Badge Text (if featured)", "default": "Core Asset" },
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "⚡" },
        { "type": "text", "id": "title", "label": "Tool Title", "default": "Habit Tracker" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Track your daily habits with full XP compounding, streak multipliers, and a 28-day audit trail." },
        { "type": "textarea", "id": "features", "label": "Features (separate with |)", "default": "Custom habits | XP per completion | Streak multipliers" }
      ]
    },
    {
      "type": "strip_stat",
      "name": "Stats Strip Item",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "6" },
        { "type": "text", "id": "label", "label": "Label", "default": "Core Tools" }
      ]
    }
  ],
  "presets": [
    {
      "name": "APEX Tools",
      "blocks": [
        { "type": "tool", "settings": { "featured": true, "badge_text": "Core Asset", "icon": "🔥", "title": "Habit Tracker", "description": "Deploy your personal habit stack. Every behavior you track earns XP and builds an audit trail you can't ignore.", "features": "Custom habit icons & colors | XP yields: 10–75 per rep | Streak multipliers up to 2×" } },
        { "type": "tool", "settings": { "icon": "📋", "title": "Daily Planner", "description": "Time-slotted task ledger. Plan your mission in the morning, review your output at night. Every task earns XP.", "features": "Time-stamped task slots | 10 XP per completion | Auto-sorted by time" } },
        { "type": "tool", "settings": { "icon": "✅", "title": "To-Do System", "description": "A structured to-do system tied to your mission briefing. Not just tasks — objectives with real consequences.", "features": "Daily mission briefings | Linked to XP system | Clear / incomplete states" } },
        { "type": "tool", "settings": { "icon": "⏱", "title": "Focus Timer", "description": "4 precision timer modes designed around peak performance science. Every completed session earns XP.", "features": "25m Deep Focus | 52m Flow State | 90m Ultra Session | 5m Debrief" } },
        { "type": "tool", "settings": { "icon": "🗺", "title": "Business Roadmap", "description": "Set your 90-day targets, break them into weekly sprints, and track real progress toward goals that matter.", "features": "90-day goal system | Weekly sprint planning | Progress tracking" } },
        { "type": "tool", "settings": { "icon": "📓", "title": "Field Journal", "description": "A private daily journal that earns XP. Document wins, failures, and observations. Your most honest dataset.", "features": "Daily entries | Per-habit notes | Mood & energy tracking" } },
        { "type": "strip_stat", "settings": { "value": "6", "label": "Core Tools" } },
        { "type": "strip_stat", "settings": { "value": "1", "label": "Connected System" } },
        { "type": "strip_stat", "settings": { "value": "∞", "label": "XP Compounding" } },
        { "type": "strip_stat", "settings": { "value": "10", "label": "Rank Levels" } }
      ]
    }
  ]
}
{% endschema %}