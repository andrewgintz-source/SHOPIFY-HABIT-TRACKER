      "label": "Counter Animation Duration (ms)",
      "default": 2600,
      "info": "2000–3200ms recommended."
    },
    {
      "type": "header",
      "content": "💬 Scarcity + Statement"
    },
    {
      "type": "text",
      "id": "scarcity",
      "label": "Scarcity Line",
      "default": "Founding pricing disappears at public launch."
    },
    {
      "type": "text",
      "id": "scarcity_em",
      "label": "Words to gold in scarcity line",
      "default": "disappears at public launch."
    },
    {
      "type": "textarea",
      "id": "statement",
      "label": "Statement Quote (below counter)",
      "default": "Build Your Future One Day at a Time"
    },
    {
      "type": "text",
      "id": "statement_em",
      "label": "Words to gold in statement",
      "default": "founding access."
    },
    {
      "type": "header",
      "content": "✨ Particles"
    },
    {
      "type": "range",
      "id": "particle_count",
      "label": "Ambient Particles",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "info": "Tiny floating gold dots + crosses. 35–50 ideal. 0 = off."
    },
    {
      "type": "header",
      "content": "📐 Spacing"
