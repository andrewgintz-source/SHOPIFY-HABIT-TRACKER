<script>
(function(){
'use strict';

/* ── CURSOR ──────────────────────────────── */
var cur  = document.getElementById('apex-cur');
var cur2 = document.getElementById('apex-cur2');
var page = document.querySelector('.apex-page');
var mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',function(e){
  mx=e.clientX; my=e.clientY;
  cur.style.left=mx+'px'; cur.style.top=my+'px';
  page.classList.add('hovering');
  clearTimeout(window._apexCH);
  window._apexCH=setTimeout(function(){page.classList.remove('hovering');},300);
});
(function tick(){
  rx+=(mx-rx)*.1; ry+=(my-ry)*.1;
  cur2.style.left=Math.round(rx)+'px';
  cur2.style.top=Math.round(ry)+'px';
  requestAnimationFrame(tick);
})();

/* ── CANVAS PARTICLES ────────────────────── */
var CV=document.getElementById('apex-cv');
var CX=CV.getContext('2d');
var P=[];
function resCV(){CV.width=innerWidth;CV.height=innerHeight;}
resCV();
window.addEventListener('resize',resCV);
function burst(x,y,col,n){
  n=n||16;
  for(var i=0;i<n;i++){
    var a=(Math.PI*2/n)*i+Math.random()*.7;
    var sp=2+Math.random()*5.5;
    P.push({x:x,y:y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-2,life:1,col:col,sz:2+Math.random()*4.5,t:Math.random()>.6?'sq':'c'});
  }
}
(function ap(){
  CX.clearRect(0,0,CV.width,CV.height);
  P=P.filter(function(p){return p.life>0;});
  P.forEach(function(p){
    p.x+=p.vx; p.y+=p.vy; p.vy+=.12; p.life-=.022; p.vx*=.984;
    CX.globalAlpha=Math.max(0,p.life);
    CX.fillStyle=p.col;
    if(p.t==='sq'){CX.fillRect(p.x-p.sz/2,p.y-p.sz/2,p.sz,p.sz);}
    else{CX.beginPath();CX.arc(p.x,p.y,p.sz,0,Math.PI*2);CX.fill();}
  });
  CX.globalAlpha=1;
  requestAnimationFrame(ap);
})();

/* ── TOAST ───────────────────────────────── */
var tQ=[],tB=false;
window.apexToast=function(m){tQ.push(m);if(!tB)nT();};
function nT(){
  if(!tQ.length){tB=false;return;}
  tB=true;
  var el=document.getElementById('apex-toast');
  el.textContent=tQ.shift(); el.classList.add('on');
  setTimeout(function(){el.classList.remove('on');setTimeout(nT,400);},2800);
}

/* ── NAV ─────────────────────────────────── */
window.addEventListener('scroll',function(){
  document.getElementById('apex-nav').classList.toggle('s',window.scrollY>60);
},{passive:true});
window.apexToggleNav=function(){
  var n=document.getElementById('apex-mobnav');
  n.style.display=n.style.display==='block'?'none':'block';
};

/* ── INTERSECTION OBSERVER ───────────────── */
if('IntersectionObserver' in window){
  var IO=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting) e.target.classList.add('v');
    });
  },{threshold:.06,rootMargin:'0px 0px -30px 0px'});
  document.querySelectorAll('.apex-page .ai,.apex-page .ai2,.apex-page .ai3').forEach(function(el){IO.observe(el);});
}

/* ── FAQ ─────────────────────────────────── */
window.apexTogFaq=function(btn){
  var it=btn.parentElement;
  var o=it.classList.contains('open');
  document.querySelectorAll('.apex-page .fi').forEach(function(x){x.classList.remove('open');});
  if(!o) it.classList.add('open');
};

/* ── PRICING TOGGLE ──────────────────────── */
var isAnn=false;
var priceOpMo='{{ section.settings.price_op_mo }}';
var priceOpAnn='{{ section.settings.price_op_ann }}';
var priceOpYr='{{ section.settings.price_op_yr }}';
var priceApMo='{{ section.settings.price_ap_mo }}';
var priceApAnn='{{ section.settings.price_ap_ann }}';
var priceApYr='{{ section.settings.price_ap_yr }}';
window.apexToggleBilling=function(){
  isAnn=!isAnn;
  document.getElementById('apex-bl-tog').classList.toggle('on',isAnn);
  document.getElementById('apex-op-amt').textContent=isAnn?priceOpAnn:priceOpMo;
  document.getElementById('apex-op-per').textContent=isAnn?'per month · billed $'+priceOpYr+'/yr':'per month';
  document.getElementById('apex-ap-amt').textContent=isAnn?priceApAnn:priceApMo;
  document.getElementById('apex-ap-per').textContent=isAnn?'per month · billed $'+priceApYr+'/yr':'per month';
};

/* ── PRICING MODAL ───────────────────────── */
var PM={
  operator:{em:'02',title:'ENLIST AS OPERATOR',sub:'Unlock the complete audit system — XP engine, all ranks, analytics, field journal, leaderboard, and operator network.'},
  apex:{em:'03',title:'JOIN APEX CLASS',sub:'The inner circle for serious operators. Limited intake. Apply to be considered for the next cohort.'}
};
window.apexOpenPM=function(t){
  var c=PM[t]||PM.operator;
  document.getElementById('apex-pm-em').textContent=c.em;
  document.getElementById('apex-pm-title').textContent=c.title;
  document.getElementById('apex-pm-sub').textContent=c.sub;
  document.getElementById('apex-pm-bg').classList.add('on');
};
window.apexClosePM=function(){
  document.getElementById('apex-pm-bg').classList.remove('on');
};
document.getElementById('apex-pm-bg').addEventListener('click',function(e){
  if(e.target===document.getElementById('apex-pm-bg')) apexClosePM();
});

/* ── INIT BURST ──────────────────────────── */
setTimeout(function(){
  burst(innerWidth*.5,innerHeight*.5,'#d4ff00',14);
  burst(innerWidth*.3,innerHeight*.4,'rgba(212,255,0,.6)',8);
  burst(innerWidth*.7,innerHeight*.55,'rgba(212,255,0,.4)',8);
},1000);

})();
</script>

