<section id="apxco-{{ section.id }}">

  <!-- Background -->
  <div class="co-grid" aria-hidden="true"></div>
  <div class="co-glow" aria-hidden="true"></div>

  <!-- Top Nav -->
  <nav class="co-nav" aria-label="Checkout navigation">
    <a class="co-nav-logo" href="{{ routes.root_url }}">
      <span class="co-nav-a">APEX</span>
      <span class="co-nav-slash">/</span>
      <span class="co-nav-tag">The Discipline Audit</span>
    </a>
    <div class="co-nav-secure" aria-label="Secure checkout">
      <span class="co-nav-secure-icon">🔒</span>
      Secure Checkout
    </div>
    <a class="co-nav-back" href="{{ routes.root_url }}">
      ← Back
    </a>
  </nav>

  <!-- Main body -->
  <div class="co-body">

    <!-- ════════════════════════════
         LEFT — FORM
    ════════════════════════════ -->
    <div class="co-left">

      <!-- XP live badge -->
      <div class="co-xp-badge co-animate" aria-hidden="true">
        <div class="co-xp-dot"></div>
        Founding Access · Limited Spots
      </div>

      <!-- Billing toggle -->
      <div class="co-step-label co-animate">
        <span class="co-step-num">01</span>
        Choose Your Billing Cycle
      </div>
      <div class="co-billing-wrap co-animate" role="group" aria-label="Billing cycle">
        <button
          class="co-bill-opt on"
          id="co-bill-mo-{{ section.id }}"
          onclick="coSetBilling('monthly','{{ section.id }}')"
          aria-pressed="true"
        >
          Monthly
        </button>
        <div class="co-bill-divider" aria-hidden="true"></div>
        <button
          class="co-bill-opt"
          id="co-bill-an-{{ section.id }}"
          onclick="coSetBilling('annual','{{ section.id }}')"
          aria-pressed="false"
        >
          Annual <span class="co-save-pill">Save 40%</span>
        </button>
      </div>

      <!-- Contact info -->
      <div class="co-step-label co-animate">
        <span class="co-step-num">02</span>
        Your Information
      </div>

      <form id="co-form-{{ section.id }}" novalidate>

        <div class="co-field-row co-animate">
          <div class="co-field-group">
            <label class="co-label" for="co-fname-{{ section.id }}">First Name</label>
            <input
              class="co-input"
              id="co-fname-{{ section.id }}"
              type="text"
              name="first_name"
              placeholder="Marcus"
              autocomplete="given-name"
              required
            />
            <span class="co-field-error" id="co-fname-err-{{ section.id }}">First name required</span>
          </div>
          <div class="co-field-group">
            <label class="co-label" for="co-lname-{{ section.id }}">Last Name</label>
            <input
              class="co-input"
              id="co-lname-{{ section.id }}"
              type="text"
              name="last_name"
              placeholder="Thorn"
              autocomplete="family-name"
              required
            />
            <span class="co-field-error" id="co-lname-err-{{ section.id }}">Last name required</span>
          </div>
        </div>

        <div class="co-field-group co-animate">
          <label class="co-label" for="co-email-{{ section.id }}">Email Address</label>
          <input
            class="co-input"
            id="co-email-{{ section.id }}"
            type="email"
            name="email"
            placeholder="you@yourdomain.com"
            autocomplete="email"
            required
          />
          <span class="co-field-error" id="co-email-err-{{ section.id }}">Valid email required</span>
        </div>

        <div class="co-field-group co-animate">
          <label class="co-label" for="co-company-{{ section.id }}">
            Company / Project
            <span style="color:var(--tx3);margin-left:6px;letter-spacing:.08em;font-size:8px">OPTIONAL</span>
          </label>
          <input
            class="co-input"
            id="co-company-{{ section.id }}"
            type="text"
            name="company"
            placeholder="Your startup, brand, or project"
            autocomplete="organization"
          />
        </div>

        <div class="co-divider"></div>

        <!-- Payment section -->
        <div class="co-step-label co-animate">
          <span class="co-step-num">03</span>
          Payment
        </div>

        <!-- Stripe card mount OR Shopify checkout redirect -->
        <div class="co-animate">
          {% if section.settings.use_stripe %}
            <!-- Stripe Elements mount point -->
            <div class="co-field-group">
              <label class="co-label">Card Details</label>
              <div class="co-card-mount" id="co-stripe-card-{{ section.id }}">
                <!-- Stripe Elements injects here -->
                <div class="co-card-mock">
                  <span class="co-card-icon">💳</span>
                  <span class="co-card-hint">Card number · MM/YY · CVC</span>
                </div>
              </div>
              <span class="co-field-error" id="co-card-err-{{ section.id }}"></span>
            </div>
          {% else %}
            <!-- Shopify native checkout — form submits to cart + redirect -->
            <div class="co-card-mount" style="display:flex;align-items:center;gap:12px;padding:16px">
              <span style="font-size:20px">🏪</span>
              <span style="font-family:var(--fm);font-size:11px;color:var(--tx2);letter-spacing:.04em;line-height:1.6">
                Clicking <strong style="color:var(--tx)">COMPLETE YOUR AUDIT</strong> below will redirect you to<br>
                Shopify's secure checkout to complete payment.
              </span>
            </div>
          {% endif %}
        </div>

        <!-- Submit -->
        <div class="co-submit-wrap co-animate">
          <button
            class="co-submit"
            type="submit"
            id="co-submit-{{ section.id }}"
            aria-label="Complete your APEX audit subscription"
          >
            COMPLETE YOUR AUDIT →
          </button>
          <div class="co-submit-sub">
            By continuing you agree to our
            <a href="{{ pages['terms-of-service'].url | default: '#' }}">Terms</a>
            &amp;
            <a href="{{ pages['privacy-policy'].url | default: '#' }}">Privacy Policy</a>
          </div>
        </div>

        <!-- Trust signals -->
        <div class="co-trust co-animate">
          <div class="co-trust-item">
            <span class="co-trust-icon">🔒</span>
            SSL Encrypted
          </div>
          <div class="co-trust-sep"></div>
          <div class="co-trust-item">
            <span class="co-trust-icon">✓</span>
            Cancel Anytime
          </div>
          <div class="co-trust-sep"></div>
          <div class="co-trust-item">
            <span class="co-trust-icon">✓</span>
            30-Day Refund
          </div>
          <div class="co-trust-sep"></div>
          <div class="co-trust-item">
            <span class="co-trust-icon">✓</span>
            No Hidden Fees
          </div>
        </div>

      </form>

      <!-- Success overlay (replaces form on completion) -->
      <div class="co-success" id="co-success-{{ section.id }}" role="status" aria-live="polite">
        <div class="co-success-icon">⚡</div>
        <div class="co-success-h">AUDIT OPEN.<br>YOU'RE IN.</div>
        <p class="co-success-sub">
          Check your inbox — your account confirmation and founding operator details are on the way.
          Your 50% founding discount is locked. Welcome to the movement.
        </p>
        <a class="co-success-btn" href="{{ section.settings.app_url | default: routes.root_url }}">
          OPEN YOUR AUDIT →
        </a>
      </div>

    </div><!-- /.co-left -->


    <!-- ════════════════════════════
         RIGHT — ORDER SUMMARY
    ════════════════════════════ -->
    <div class="co-right">

      <div class="co-summary-title">Order Summary</div>

      <!-- Plan card — updates via JS -->
      <div class="co-plan-card" id="co-plan-card-{{ section.id }}">
        <div class="co-plan-tier" id="co-plan-tier-{{ section.id }}">Tier 02</div>
        <div class="co-plan-name" id="co-plan-name-{{ section.id }}">OPERATOR</div>
        <div class="co-plan-price-row">
          <span class="co-plan-price-cur">$</span>
          <span class="co-plan-price-num" id="co-plan-price-{{ section.id }}">{{ section.settings.price_op_mo }}</span>
          <span class="co-plan-price-per" id="co-plan-per-{{ section.id }}">/mo</span>
        </div>
      </div>

      <!-- Feature list — updates via JS -->
      <ul class="co-feat-list" id="co-feat-list-{{ section.id }}">
        <li class="co-feat"><span class="co-feat-ic">+</span>Unlimited habit assets</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>Full XP &amp; 10-rank system</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>XP multipliers on streaks</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>All 4 war room timer modes</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>28-day audit trail &amp; heatmap</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>Field journal + habit notes</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>Global leaderboard access</li>
        <li class="co-feat"><span class="co-feat-ic">+</span>Operator Discord</li>
      </ul>

      <!-- Subtotal rows -->
      <div class="co-line">
        <span id="co-subtotal-lbl-{{ section.id }}">Operator · Monthly</span>
        <span class="co-line-val" id="co-subtotal-val-{{ section.id }}">${{ section.settings.price_op_mo }}/mo</span>
      </div>
      <div class="co-line">
        <span>Founding Discount</span>
        <span class="co-line-val acid" id="co-discount-{{ section.id }}">—</span>
      </div>
      <div class="co-line">
        <span>Setup Fee</span>
        <span class="co-line-val acid">Free</span>
      </div>

      <!-- Total -->
      <div class="co-total-row">
        <span class="co-total-lbl">Total Today</span>
        <span class="co-total-val" id="co-total-{{ section.id }}">${{ section.settings.price_op_mo }}</span>
      </div>

      <!-- 30-day guarantee -->
      <div class="co-guarantee">
        <div class="co-guarantee-icon">🛡</div>
        <div>
          <div class="co-guarantee-title">30-DAY GUARANTEE</div>
          <div class="co-guarantee-text">
            If APEX doesn't deliver value in the first 30 days, we'll refund you completely.
            No forms. No questions. No dark patterns.
          </div>
        </div>
      </div>

      <!-- Stripe / payment logos -->
      <div class="co-stripe-row">
        <span class="co-stripe-lbl">Secured by</span>
        <div class="co-card-logos">
          <span class="co-card-logo">Stripe</span>
          <span class="co-card-logo">Visa</span>
          <span class="co-card-logo">MC</span>
          <span class="co-card-logo">Amex</span>
          <span class="co-card-logo">PayPal</span>
        </div>
      </div>

    </div><!-- /.co-right -->
  </div><!-- /.co-body -->

</section>

<script>
(function() {
'use strict';

var SID = '{{ section.id }}';

/* ── Plan data from schema ─────────────────── */
var PLANS = {
  operator: {
    tier:     'Tier 02',
    name:     'OPERATOR',
    mo:       '{{ section.settings.price_op_mo }}',
    ann:      '{{ section.settings.price_op_ann }}',
    yrTotal:  '{{ section.settings.price_op_yr }}',
    variantMo:  '{{ section.settings.variant_op_mo }}',
    variantAnn: '{{ section.settings.variant_op_ann }}',
    checkoutMo:  '{{ section.settings.checkout_url_op_mo }}',
    checkoutAnn: '{{ section.settings.checkout_url_op_ann }}',
    feats: [
      'Unlimited habit assets',
      'Full XP &amp; 10-rank system',
      'XP multipliers on streaks',
      'All 4 war room timer modes',
      '28-day audit trail &amp; heatmap',
      'Field journal + habit notes',
      'Global leaderboard access',
      'Operator Discord'
    ]
  },
  apex_class: {
    tier:     'Tier 03',
    name:     'APEX CLASS',
    mo:       '{{ section.settings.price_ap_mo }}',
    ann:      '{{ section.settings.price_ap_ann }}',
    yrTotal:  '{{ section.settings.price_ap_yr }}',
    variantMo:  '{{ section.settings.variant_ap_mo }}',
    variantAnn: '{{ section.settings.variant_ap_ann }}',
    checkoutMo:  '{{ section.settings.checkout_url_ap_mo }}',
    checkoutAnn: '{{ section.settings.checkout_url_ap_ann }}',
    feats: [
      'Everything in Operator',
      '1-on-1 accountability pairing',
      'Private Apex Class Discord',
      'Weekly group debrief calls',
      'Custom audit programs',
      'Early access to all features',
      'APEX gear drops',
      'Direct founder access'
    ]
  }
};

/* ── Read plan from URL param ──────────────── */
function getParam(key) {
  var params = new URLSearchParams(window.location.search);
  return params.get(key) || 'operator';
}

var currentPlan    = getParam('plan');
var currentBilling = 'monthly';

if (!PLANS[currentPlan]) currentPlan = 'operator';

/* ── DOM refs ──────────────────────────────── */
function el(id) { return document.getElementById(id + '-' + SID); }

var domTier        = el('co-plan-tier');
var domName        = el('co-plan-name');
var domPrice       = el('co-plan-price');
var domPer         = el('co-plan-per');
var domFeatList    = el('co-feat-list');
var domSubtotalLbl = el('co-subtotal-lbl');
var domSubtotalVal = el('co-subtotal-val');
var domDiscount    = el('co-discount');
var domTotal       = el('co-total');
var domBillMo      = el('co-bill-mo');
var domBillAn      = el('co-bill-an');
var domSubmit      = el('co-submit');
var domForm        = el('co-form');
var domSuccess     = el('co-success');

/* ── Render summary panel ──────────────────── */
function renderSummary() {
  var p = PLANS[currentPlan];
  var isAnn = currentBilling === 'annual';

  domTier.textContent = p.tier;
  domName.textContent = p.name;
  domPrice.textContent = isAnn ? p.ann : p.mo;
  domPer.textContent   = isAnn ? '/mo · billed annually' : '/mo';

  /* Feature list */
  domFeatList.innerHTML = p.feats.map(function(f) {
    return '<li class="co-feat"><span class="co-feat-ic">+</span>' + f + '</li>';
  }).join('');

  /* Subtotal */
  var priceLabel = p.name + ' · ' + (isAnn ? 'Annual' : 'Monthly');
  var priceVal   = isAnn ? ('$' + p.ann + '/mo') : ('$' + p.mo + '/mo');
  var totalVal   = isAnn ? ('$' + p.yrTotal + '/yr') : ('$' + p.mo + '/mo');
  domSubtotalLbl.textContent = priceLabel;
  domSubtotalVal.textContent = priceVal;
  domTotal.textContent       = totalVal;

  /* Discount — show founding note on annual */
  if (isAnn) {
    domDiscount.textContent = 'Annual rate applied';
    domDiscount.style.color = 'var(--acid)';
  } else {
    domDiscount.textContent = '—';
    domDiscount.style.color = '';
  }
}

/* ── Billing toggle ────────────────────────── */
window['coSetBilling'] = function(mode, sid) {
  if (sid !== SID) return;
  currentBilling = mode;
  domBillMo.classList.toggle('on', mode === 'monthly');
  domBillAn.classList.toggle('on', mode === 'annual');
  domBillMo.setAttribute('aria-pressed', mode === 'monthly' ? 'true' : 'false');
  domBillAn.setAttribute('aria-pressed', mode === 'annual'  ? 'true' : 'false');
  renderSummary();
};

/* ── Form validation ───────────────────────── */
function validate() {
  var ok = true;

  function check(inputEl, errEl, testFn) {
    if (!testFn(inputEl.value.trim())) {
      inputEl.classList.add('error');
      errEl.classList.add('on');
      ok = false;
    } else {
      inputEl.classList.remove('error');
      errEl.classList.remove('on');
    }
  }

  check(
    document.getElementById('co-fname-' + SID),
    document.getElementById('co-fname-err-' + SID),
    function(v) { return v.length >= 1; }
  );
  check(
    document.getElementById('co-lname-' + SID),
    document.getElementById('co-lname-err-' + SID),
    function(v) { return v.length >= 1; }
  );
  check(
    document.getElementById('co-email-' + SID),
    document.getElementById('co-email-err-' + SID),
    function(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
  );

  return ok;
}

/* Live validation on blur */
['co-fname','co-lname','co-email'].forEach(function(base) {
  var inp = document.getElementById(base + '-' + SID);
  if (inp) {
    inp.addEventListener('blur', function() {
      var errEl = document.getElementById(base + '-err-' + SID);
      if (inp.value.trim().length > 0) {
        inp.classList.remove('error');
        if (errEl) errEl.classList.remove('on');
      }
    });
  }
});

/* ── Form submit ───────────────────────────── */
domForm.addEventListener('submit', function(e) {
  e.preventDefault();

  if (!validate()) return;

  var p       = PLANS[currentPlan];
  var isAnn   = currentBilling === 'annual';
  var useStripe = {{ section.settings.use_stripe | json }};

  /* Loading state */
  domSubmit.classList.add('loading');
  domSubmit.textContent = 'PROCESSING...';

  if (useStripe) {
    /* ── STRIPE PATH ───────────────────────────
       Replace this block with your real Stripe
       Checkout session creation API call.
       The URL below is a placeholder.
    ──────────────────────────────────────────── */
    var stripeUrl = isAnn ? p.checkoutAnn : p.checkoutMo;
    if (stripeUrl && stripeUrl.length > 0) {
      setTimeout(function() { window.location.href = stripeUrl; }, 600);
    } else {
      /* Demo: show success state */
      setTimeout(showSuccess, 1400);
    }
  } else {
    /* ── SHOPIFY NATIVE CHECKOUT PATH ──────────
       Adds the selected variant to cart then
       redirects to /checkout
    ──────────────────────────────────────────── */
    var variantId = isAnn ? p.variantAnn : p.variantMo;

    if (variantId && variantId.length > 0 && variantId !== '') {
      /* Add to cart via AJAX then redirect */
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        /* Pass email as checkout prefill */
        var email = document.getElementById('co-email-' + SID).value;
        var checkoutUrl = '/checkout?checkout[email]=' + encodeURIComponent(email);
        window.location.href = checkoutUrl;
      })
      .catch(function() {
        domSubmit.classList.remove('loading');
        domSubmit.textContent = 'COMPLETE YOUR AUDIT →';
        alert('Something went wrong adding to cart. Please try again.');
      });
    } else {
      /* No variant configured — show success demo */
      setTimeout(showSuccess, 1400);
    }
  }
});

/* ── Success state ─────────────────────────── */
function showSuccess() {
  domForm.style.display = 'none';
  domSuccess.classList.add('on');
  /* Scroll to top of section */
  document.getElementById('apxco-' + SID).scrollIntoView({ behavior: 'smooth' });
}

/* ── Init ──────────────────────────────────── */
renderSummary();

})();
</script>

