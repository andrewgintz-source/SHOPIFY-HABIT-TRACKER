      "id": "offer_text",
      "label": "Offer Badge Text",
      "info": "Shown in gold bar above headline",
      "default": "50% Off for Early Operators"
    },
    {
      "type": "text",
      "id": "headline_l1",
      "label": "Headline — Line 1",
      "default": "Join Early."
    },
    {
      "type": "text",
      "id": "headline_l2",
      "label": "Headline — Line 2 (gold)",
      "default": "Lock 50% Off. Enter APEX First."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "APEX is the level-up system for young entrepreneurs who want discipline, structure, business focus, and real progress."
    },
    {
      "type": "text",
      "id": "divider_text",
      "label": "Divider Label",
      "default": "Secure your founding spot"
    },
    {
      "type": "header",
      "content": "📝 Form"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Claim Founding Access"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Success Message",
      "default": "✓ You're in. Your 50% founding discount is locked. We'll notify you before launch."
    },
    {
      "type": "header",
      "content": "🔢 Waitlist Counter"
    },
    {
      "type": "number",
