      "label": "Current Count",
      "info": "Update this manually as your list grows. The page animates to this number.",
      "default": 327
    },
    {
      "type": "number",
      "id": "goal_count",
      "label": "Launch Goal",
      "info": "Number at which founding access closes. Controls the progress bar.",
      "default": 500
    },
    {
      "type": "text",
      "id": "count_label",
      "label": "Count Label",
      "default": "operators already inside"
    },
    {
      "type": "number",
